    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sentinel/core": "*",
    "@sentinel/audit": "*"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "typescript": "^5.7.0"
  }
}
