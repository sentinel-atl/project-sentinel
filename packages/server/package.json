{
  "name": "@sentinel-atl/server",
  "version": "0.3.0",
  "description": "STP-compliant HTTP server — exposes Sentinel's trust pipeline as a language-agnostic REST API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sentinel-atl/core": "workspace:*",
    "@sentinel-atl/audit": "workspace:*",
    "@sentinel-atl/reputation": "workspace:*",
    "@sentinel-atl/revocation": "workspace:*",
    "@sentinel-atl/handshake": "workspace:*",
    "@sentinel-atl/safety": "workspace:*",
    "@sentinel-atl/offline": "workspace:*",
    "@sentinel-atl/gateway": "workspace:*",
    "@sentinel-atl/sdk": "workspace:*",
    "@sentinel-atl/hardening": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sentinel-atl/project-sentinel.git",
    "directory": "packages/server"
  },
  "keywords": [
    "sentinel",
    "stp",
    "trust-protocol",
    "http-server",
    "ai-agents",
    "authentication",
    "reputation"
  ],
  "homepage": "https://github.com/sentinel-atl/project-sentinel#readme",
  "bugs": {
    "url": "https://github.com/sentinel-atl/project-sentinel/issues"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
