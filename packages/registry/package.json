{
  "name": "@sentinel-atl/registry",
  "version": "0.4.0",
  "description": "Trust Registry API — publish, query, and verify Sentinel Trust Certificates",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sentinel-registry": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sentinel-atl/scanner": "workspace:*",
    "@sentinel-atl/hardening": "workspace:*",
    "@sentinel-atl/store": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "typescript": "^5.7.0",
    "@types/node": "^20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sentinel-atl/project-sentinel.git",
    "directory": "packages/registry"
  },
  "keywords": [
    "sentinel",
    "trust",
    "registry",
    "mcp",
    "certificate",
    "badge"
  ]
}
