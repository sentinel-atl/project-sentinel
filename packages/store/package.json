{
  "name": "@sentinel-atl/store",
  "version": "0.1.2",
  "description": "Persistent storage adapters for Sentinel — Redis, PostgreSQL, SQLite, and in-memory backends",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "ioredis": ">=5.0.0",
    "pg": ">=8.0.0",
    "better-sqlite3": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": { "optional": true },
    "pg": { "optional": true },
    "better-sqlite3": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sentinel-atl/project-sentinel.git",
    "directory": "packages/store"
  },
  "keywords": [
    "sentinel",
    "storage",
    "redis",
    "postgresql",
    "sqlite",
    "persistence",
    "ai-agent",
    "trust"
  ],
  "homepage": "https://github.com/sentinel-atl/project-sentinel#readme",
  "bugs": {
    "url": "https://github.com/sentinel-atl/project-sentinel/issues"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
